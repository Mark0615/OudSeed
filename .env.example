# GCP
GCP_PROJECT_ID=oudseed
BIGQUERY_DATASET=ads_pipeline
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.example.json

# Meta Ads
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token
META_API_TIMEOUT_SECONDS=60

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-client-id
GOOGLE_ADS_CLIENT_SECRET=your-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
# Use the manager account customer ID without dashes when needed; leave empty for
# direct customer access.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-login-customer-id

# LINE Ads - future phase
LINE_ADS_ACCESS_KEY=your-line-access-key
LINE_ADS_SECRET_KEY=your-line-secret-key

# AI reports - future phase
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=1800
OPENAI_TIMEOUT_SECONDS=60
AI_REPORT_TYPE=monthly
# Leave AI_REPORT_PERIOD_START_DATE empty for scheduled reports.
# weekly defaults to the previous complete week; monthly defaults to the previous month.
AI_REPORT_PERIOD_START_DATE=
AI_REPORT_CLIENT_ID=your-client-id
AI_REPORT_LIMIT=10
AI_REPORT_DEPTH=standard
AI_REPORT_TIMEZONE=Asia/Taipei

# Email delivery
AI_REPORT_EMAIL_TO=recipient@example.com
AI_REPORT_EMAIL_SUBJECT=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-sender-email@example.com
SMTP_PASSWORD=your-smtp-or-app-password
SMTP_FROM_EMAIL=your-sender-email@example.com
SMTP_USE_TLS=true
